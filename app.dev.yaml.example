# Development config — demo Kalshi keys, demo API endpoints.
# Copy to app.dev.yaml and fill in demo values.
# Auto-selected when APP_ENV is unset and this file exists.

environment: demo
kalshi_api_key_id: "00000000-0000-0000-0000-000000000000"
kalshi_private_key_path: /path/to/demo_key.pem
db_path: kalshi_tennis.db
metrics_addr: "127.0.0.1:6060"
apitennis_api_key: ""
disable_ws_data_save: false
rest_base_url: "https://external-api.demo.kalshi.co/trade-api/v2"
ws_url: "wss://external-api-ws.demo.kalshi.co/trade-api/ws/v2"
backtest_cache_ttl_min: 30
