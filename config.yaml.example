# THIS FILE IS INPUT FOR THE ONE-TIME MIGRATION SCRIPT ONLY.
# The main app never reads config.yaml. Run:
#   go run ./cmd/migrate-config
# to seed app_config, liquidity_pool, and strategy_config tables.
# Then delete config.yaml.
#
# Kalshi API credentials (required)
api_key_id: your-key-id-here
private_key_path: /path/to/private_key.pem

# Environment: "demo" or "prod"
environment: demo

# SQLite database path (relative to working dir)
db_path: kalshi_tennis.db

# Tennis series tickers to scan (defaults to all 12 core series if omitted)
series_tickers:
  - KXATPMATCH
  - KXWTAMATCH
  - KXITFMATCH
  - KXITFWMATCH
  - KXATPCHALLENGERMATCH
  - KXWTACHALLENGERMATCH
  - KXTENNISEXHIBITION
  - KXCHALLENGERMATCH
  - KXATPDOUBLES
  - KXWTADOUBLES
  - KXITFDOUBLES
  - KXITFWDOUBLES

# Scanner interval (hours between daily scans)
scan_interval_hours: 24

# How early before occurrence_datetime to start WS tracking (minutes)
track_lead_minutes: 5

# WebSocket reconnection backoff (seconds)
ws_min_backoff_secs: 1
ws_max_backoff_secs: 30

# SQLite batch insert settings
batch_size: 500
flush_timeout_ms: 250

# REST client per-request timeout (seconds)
http_timeout_secs: 30

# REST client max requests per second
rate_limit_rps: 15

# Scheduler DB poll interval (seconds)
scheduler_poll_secs: 30

# pprof + runtime metrics HTTP server port (0 = disabled)
metrics_port: 6060

# API-Tennis scraper — WebSocket real-time push
# Get API key at https://api-tennis.com/
apitennis_enabled: true
apitennis_api_key: your-api-tennis-key-here
apitennis_timezone: "+00:00"

# Reconciler — fills settlement gaps by polling REST for unresolved markets
# Markets with orders but no result (missed WS settled event) get fetched and updated
reconciler_interval_secs: 300

# Schedule checker — refreshes stale occurrence_ts from REST
# Kalshi can update match start times after market creation (rain delays, etc).
# This polls upcoming markets and updates the DB + strategy runtime cache.
schedule_checker_interval_secs: 120

# Close timer strategy — buys the favorite N minutes before market close.
# Backtest: favorite ≥85c at T-10min won 100% (Sharpe 1.01).
close_timer_enabled: false
close_timer_lead_minutes: 10
close_timer_min_price: 0.85
close_timer_poll_secs: 30
close_timer_size: 50

# Order quota — throttles order emission for the REAL trading path only.
# Paper mode bypasses QuotaGuard entirely: every strategy fires independently
# so the paper trail captures the full signal surface for backtesting.
# These fields are reserved for future real-trading wiring (currently unused).
order_quota_enabled: false
order_quota_cooldown_secs: 30   # per-market: first order passes, rest dropped within window
order_quota_max_per_sec: 2      # global rate limit across all markets
order_quota_daily_limit: 100    # hard daily ceiling (0 = unlimited)

# Paper trading budget (simulated spend tracking)
paper_budget_total: 1000.00    # starting paper budget in dollars (0 = no tracking)
paper_budget_floor: 50.00      # stop paper orders when remaining drops below this

# Real trading — submits LIVE orders to Kalshi. DANGEROUS.
# When false: paper only (no real orders submitted).
# When true: IOC bid orders submitted via REST after passing real quota guard.
real_trading_enabled: false
real_bankroll: 1000             # Kelly bankroll for real order sizing
real_order_timeout_secs: 10     # per-order HTTP timeout

# Real trading budget (live spend tracking)
real_budget_total: 100.00      # starting real budget in dollars (0 = no tracking)
real_budget_floor: 5.00        # stop real orders when remaining drops below this

# Kelly sizing — fraction of bankroll to risk per order
# size = kelly_fraction * f_kelly * bankroll, where f_kelly = (p - c) / (1 - c)
kelly_fraction: 0.25
