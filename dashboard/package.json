{
	"name": "dashboard",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "curl -s http://127.0.0.1:6060/metrics > /dev/null 2>&1 || (cd .. && go run . &) && sleep 1 && vite dev",
		"dev:web": "vite dev",
		"dev:prod": "VITE_BACKEND_URL=http://192.168.1.246:6060 vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.4.2",
		"concurrently": "^10.0.3",
		"jsdom": "^25.0.1",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^3.2.7"
	},
	"dependencies": {
		"chart.js": "^4.5.1",
		"chartjs-plugin-zoom": "^2.2.0",
		"hammerjs": "^2.0.8"
	}
}
